###############################################################################
### REQUIRED ENVIRONMENT VARIABLES - SENSITIVE INFORMATION                  ###
### DO NOT STORE RAW SECRETS HERE IN PLAINTEXT IF AVOIDABLE                 ###
### DO NOT UPLOAD OR SHARE THIS FILE UNDER ANY CIRCUMSTANCES                ###
###############################################################################

# ── CRE / Blockchain ──────────────────────────────────────────────────────
CRE_ETH_PRIVATE_KEY=your-eth-private-key
CRE_TARGET=staging-settings
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Optional runtime mode: auto | simulate | deployed
CRE_RUNTIME_MODE=auto

# Deployment target:
# - sepolia: current ERC-8004 + CRE workflow stack
# - hedera: HCS-10/HCS-11 + Bonzo Vault runtime
MEMORYVAULT_DEPLOYMENT_TARGET=sepolia

# ── Hedera / HCS-10 + HCS-11 ───────────────────────────────────────────────
# Private keys may be provided directly or via *_FILE, but never both.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_OPERATOR_KEY_FILE=
HEDERA_AGENT_ID=
HEDERA_AGENT_KEY=
HEDERA_AGENT_KEY_FILE=
HEDERA_MEMORY_TOPIC_ID=
HEDERA_MIRROR_NODE_URL=
HEDERA_STATE_STORE_PATH=.agent/hedera-state.json
HEDERA_MEMORY_S3_BUCKET=
HEDERA_MEMORY_S3_REGION=
HEDERA_MEMORY_S3_PREFIX=agents
HEDERA_AGENT_PROFILE_NAME=MemoryVault Hedera
HEDERA_AGENT_PROFILE_DESCRIPTION=Autonomous Hedera deployment for Bonzo Vaults with MemoryVault audit commitments.
HEDERA_AGENT_PROFILE_TYPE=autonomous
HEDERA_AGENT_PROFILE_MODEL=gemini-2.5-flash
HEDERA_AGENT_PROFILE_CREATOR=
# Comma-separated HCS-11 AI capability ids
HEDERA_AGENT_PROFILE_CAPABILITIES=7,9,10,13,17,18
HEDERA_AGENT_PROFILE_PICTURE_PATH=

BONZO_DATA_SOURCE=mock
# Local-development execution mode:
# - simulate: log Bonzo deposit/withdraw plans only (default/dev-safe)
# - live: require a Hedera EVM RPC endpoint plus explicit non-mainnet vault inputs
BONZO_EXECUTION_MODE=simulate
BONZO_MIN_APY_DELTA_BPS=0
# Explicit execution-plane signer ownership:
# - operator: Bonzo writes reuse the Hedera operator signer intentionally
# - dedicated: Bonzo writes require BONZO_EXECUTOR_* credentials
BONZO_EXECUTOR_MODE=operator
BONZO_EXECUTOR_ACCOUNT_ID=
BONZO_EXECUTOR_PRIVATE_KEY=
BONZO_EXECUTOR_PRIVATE_KEY_FILE=
# Bonzo vault discovery inputs:
# - BONZO_CONTRACT_VAULTS_JSON: official deployed-vault catalog override (JSON array)
# - BONZO_CONTRACT_VAULT_SNAPSHOTS_JSON: TVL/APR/APY snapshots keyed by vaultId (JSON array)
# - BONZO_CONTRACT_VAULTS_API_URL: project-managed API/indexer endpoint for api mode
# - BONZO_CONTRACT_POSITIONS_JSON / BONZO_CONTRACT_POSITIONS_API_URL: execution-account position inputs
# - BONZO_CONTRACT_SINGLE_ASSET_FACTORY / BONZO_CONTRACT_DUAL_ASSET_DEPLOYER: optional strategy-family address hints
# - BONZO_CONTRACT_RPC_URL: Hedera JSON-RPC relay for live Bonzo execution
# Live-mode notes:
# - BONZO_DATA_SOURCE=mock is not allowed with BONZO_EXECUTION_MODE=live
# - BONZO_CONTRACT_VAULTS_JSON is required for live execution outside mainnet
BONZO_CONTRACT_VAULTS_JSON=
BONZO_CONTRACT_VAULT_SNAPSHOTS_JSON=
BONZO_CONTRACT_VAULTS_API_URL=
BONZO_CONTRACT_POSITIONS_JSON=
BONZO_CONTRACT_POSITIONS_API_URL=
BONZO_CONTRACT_SINGLE_ASSET_FACTORY=
BONZO_CONTRACT_DUAL_ASSET_DEPLOYER=
BONZO_CONTRACT_RPC_URL=

PRIVATE_HTTP_MODE=stub
OAUTH3_PROXY_URL=
OAUTH3_OWNER_APPROVAL_MODE=
BONZO_MONITOR_MAX_APY_DROP_BPS=200
BONZO_MONITOR_MAX_SNAPSHOT_AGE_MS=
BONZO_MONITOR_MIN_HEALTHY_TVL_USD=
BONZO_MONITOR_EXIT_ON_REWARD_CHANGE=false

# Shared MemoryVault blob-store secrets
AWS_ACCESS_KEY_ID_VAR=
AWS_SECRET_ACCESS_KEY_VAR=
AES_KEY_VAR=

# Deployed CRE trigger gateway + workflow IDs
CRE_GATEWAY_URL=https://your-cre-gateway.example.com
CRE_WORKFLOW_ID_SCANNER=
CRE_WORKFLOW_ID_MONITOR=
CRE_WORKFLOW_ID_MEMORY_WRITER=
CRE_WORKFLOW_ID_AUDIT_READER=

# Optional override key for CRE HTTP trigger JWT signing
CRE_HTTP_TRIGGER_PRIVATE_KEY=

# ── Gemini configuration ───────────────────────────────────────────────────
GEMINI_API_KEY_VAR=your-gemini-api-key

# ── ERC-8004 (Sepolia) ────────────────────────────────────────────────────
# Chain ID (Sepolia = 11155111)
ERC8004_CHAIN_ID=11155111
# Public base URL where registration JSON files are served (e.g. GitHub Pages)
ERC8004_BASE_URL=https://example.github.io/cre-por-llm-demo
# Optional: override computed URI (defaults to {BASE_URL}/erc8004/registration.sepolia.json)
ERC8004_REGISTRATION_URI=
# Deployed registry addresses (deployed 2026-04-01)
ERC8004_IDENTITY_REGISTRY=0x2042A98Bf0AF522c8aa2B879fc0bF627454F5016
ERC8004_REPUTATION_REGISTRY=0x898EAeA8ce4b1Bc42Bf996788B62e83487bAAdA5
# Agent ID — set after running erc8004:register (prints predictedAgentId)
ERC8004_AGENT_ID=

# Optional separate owner key for registration updates
ERC8004_OWNER_PRIVATE_KEY=

# Dedicated watchtower publisher key
ERC8004_WATCHTOWER_PRIVATE_KEY=

# ── Zama Confidential Transfer (agent private transfer path) ───────────────
# Mode:
# - simulate: log transfer intent only (default/dev-safe)
# - onchain: submit confidential token transfer transaction
ZAMA_TRANSFER_MODE=simulate
ZAMA_RPC_URL=
ZAMA_CHAIN_ID=11155111
ZAMA_CONFIDENTIAL_TOKEN_ADDRESS=

# Optional dedicated signer key; falls back to CRE_ETH_PRIVATE_KEY if unset
ZAMA_PRIVATE_KEY=

# Encrypted input payloads keyed by plaintext amount string.
# Example:
# {"1000000000":{"handle":"0x...32bytes","inputProof":"0x..."}}
ZAMA_ENCRYPTED_INPUTS_JSON=

# Optional fallback payload when amount-specific entry is missing
ZAMA_DEFAULT_HANDLE=
ZAMA_DEFAULT_INPUT_PROOF=

# Optional recipients used by agent/index.ts transfer calls
LP_POSITION_CONFIDENTIAL_ADDRESS=
HOLD_WALLET_CONFIDENTIAL_ADDRESS=

# ── X Layer / OKX Agent PvP Arena ──────────────────────────────────────────
# Deployment target:
# - okx: X Layer agent loop + OKX Vault Wallet + Onchain OS MCP
# - hedera: HCS-10/HCS-11 + Bonzo Vault runtime
MEMORYVAULT_DEPLOYMENT_TARGET=okx

# X Layer network: mainnet | testnet
X_LAYER_NETWORK=testnet
# Primary RPC endpoint (required). Public fallbacks: https://testrpc.xlayer.tech, https://xlayertestrpc.okx.com
X_LAYER_RPC_URL=https://testrpc.xlayer.tech
# Agent wallet private key — OKX Vault Wallet key share or raw key
# Prefer using OKX Vault API; raw key is fallback (clear security notes in README)
X_LAYER_PRIVATE_KEY=
X_LAYER_PRIVATE_KEY_FILE=
# OKX Vault Wallet — optional: derive key via OKX Vault API instead of raw private key
OKX_VAULT_API_KEY=
OKX_VAULT_API_SECRET=
OKX_VAULT_API_PASSPHRASE=
# Onchain OS MCP — optional; falls back to direct RPC + viem
ONCHAINOS_API_KEY_VAR=
ONCHAINOS_MCP_ENDPOINT=https://mcp.okx.com/v1/mcp
# Arena contract address (deployed after Task 3.4)
X_LAYER_ARENA_ADDRESS=0x824af7339b4fFC04D0FD867953eCbfCc75dEAf18
# Agent loop interval in milliseconds (default: 60000 = 1 min)
AGENT_LOOP_INTERVAL_MS=60000
