###############################################################################
### REQUIRED ENVIRONMENT VARIABLES — MemoryVault Agent Protocol             ###
### Copy to .env and fill in actual values. .env is gitignored.             ###
### DO NOT UPLOAD OR SHARE .env UNDER ANY CIRCUMSTANCES                     ###
###############################################################################

# ── CRE / Blockchain ──
CRE_ETH_PRIVATE_KEY=your-eth-private-key
CRE_TARGET=staging-settings
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Gemini LLM (Risk Analysis Skill) ──
GEMINI_API_KEY_VAR=your-gemini-api-key

# ── AWS S3 (MemoryVault episodic storage) ──
AWS_ACCESS_KEY_ID_VAR=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY_VAR=your-aws-secret-access-key

# ── Mock Data API ──
DATA_API_KEY_VAR=demo-secret-key-12345

# ── AES-GCM Encryption (MemoryVault blobs) ──
AES_KEY_VAR=your-aes-256-key-hex

# ── Pushover Notifications (Integrity Checker) ──
PUSHOVER_USER_KEY_VAR=your-pushover-user-key
PUSHOVER_API_TOKEN_VAR=your-pushover-api-token

# ── Deploy-mode trigger wiring ──
CRE_GATEWAY_URL=https://your-cre-gateway.example.com
CRE_WORKFLOW_ID_SCANNER=
CRE_WORKFLOW_ID_MONITOR=
CRE_WORKFLOW_ID_MEMORY_WRITER=
CRE_WORKFLOW_ID_AUDIT_READER=
CRE_HTTP_TRIGGER_PRIVATE_KEY=

# ── ERC-8004 (Sepolia) ──
ERC8004_CHAIN_ID=11155111
ERC8004_BASE_URL=https://example.github.io/cre-por-llm-demo
ERC8004_IDENTITY_REGISTRY=
ERC8004_REPUTATION_REGISTRY=
ERC8004_AGENT_ID=
ERC8004_WATCHTOWER_PRIVATE_KEY=
